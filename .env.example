# NyaAI Backend Configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# MongoDB (required for persistence — empty = in-memory fallback)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=nyaai

# JWT Authentication (REQUIRED: set a strong random value in production)
JWT_SECRET=generate-a-random-64-char-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis (optional — enables embedding cache + rate limiting across workers)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins, no spaces)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
